---
import CopyButton from "./CopyButton.astro";

const navItems = [
  { label: "Intro", href: "/intro" },
  { label: "Wiki", href: "https://docs.starlin.world", external: true },
  { label: "Gallery", href: "/gallery" },
  { label: "Join", href: "/join" },
];
---

<header class="bg-background text-white py-3 px-6 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto">
    <!-- Desktop Layout -->
    <div class="hidden md:flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img
          src="/brand/logo_english_white.svg"
          alt="StarlinWorld"
          class="w-48"
        />
      </a>

      <!-- Nav Items -->
      <ul class="flex items-center gap-8 md:gap-16">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noopener noreferrer" : undefined}
                class="text-base font-display font-medium hover:text-muted transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Copy Button -->
      <CopyButton />
    </div>

    <!-- Mobile Layout -->
    <div class="md:hidden">
      <div class="flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center">
          <img
            src="/brand/logo_english_white.svg"
            alt="StarlinWorld"
            class="w-48"
          />
        </a>

        <!-- Menu Button -->
        <button
          id="mobile-menu-button"
          class="p-2 hover:bg-white/10 rounded-lg transition-colors"
          aria-label="Toggle menu"
        >
          <i class="fa-solid fa-bars text-2xl"></i>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div
        id="mobile-menu"
        class="fixed inset-0 bg-background z-50 transform translate-x-full transition-transform duration-300 flex flex-col"
      >
        <!-- Menu Header -->
        <div
          class="flex items-center justify-between p-4 border-b border-white/10"
        >
          <a href="/" class="flex items-center">
            <img
              src="/brand/logo_english_white.svg"
              alt="StarlinWorld"
              class="w-48"
            />
          </a>
          <button
            id="mobile-menu-close"
            class="p-2 hover:bg-white/10 rounded-lg transition-colors"
            aria-label="Close menu"
          >
            <i class="fa-solid fa-xmark text-2xl"></i>
          </button>
        </div>

        <!-- Menu Items -->
        <ul class="flex-1 flex flex-col gap-1 p-4">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener noreferrer" : undefined}
                  class="block text-lg font-medium py-3 px-4 hover:bg-white/5 rounded-lg transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Copy Button at Bottom -->
        <div class="p-4 border-t border-white/10">
          <CopyButton />
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuButton = document.getElementById("mobile-menu-button");
  const menuClose = document.getElementById("mobile-menu-close");
  const mobileMenu = document.getElementById("mobile-menu");

  menuButton?.addEventListener("click", () => {
    mobileMenu?.classList.remove("translate-x-full");
  });

  menuClose?.addEventListener("click", () => {
    mobileMenu?.classList.add("translate-x-full");
  });

  // Close menu when clicking a nav link
  const mobileMenuLinks = mobileMenu?.querySelectorAll("a");
  mobileMenuLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      if (!link.getAttribute("target")) {
        mobileMenu?.classList.add("translate-x-full");
      }
    });
  });
</script>
