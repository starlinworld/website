---
import { socialLinks } from "../data.ts";
import en from "../locales/en";

const currentYear = new Date().getFullYear();
---

<footer class="bg-background text-text py-8 px-6">
  <div class="max-w-7xl mx-auto">
    <div
      class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6"
    >
      <!-- Copyright Info -->
      <div class="flex flex-col md:flex-row items-start md:items-center gap-4">
        <a href="/" class="flex items-center">
          <img
            src="/brand/logo_english_white.svg"
            alt="StarlinWorld"
            class="h-12"
            data-i18n-logo
          />
        </a>
        <div class="text-sm text-muted leading-relaxed">
          <p>&copy; 2017-{currentYear} StarlinWorld.</p>
          <p>
            <span>Design:</span> <a
              href="https://katorly.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text hover:text-muted transition-colors">Katorly Lab</a
            >.
          </p>
          <p data-i18n="footer.unofficialMinecraft">{en.footer.unofficialMinecraft}</p>
          <p data-i18n="footer.notAssociated">{en.footer.notAssociated}</p>
        </div>
      </div>

      <!-- Social Icons -->
      <div class="flex items-center gap-4 self-end md:self-auto">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted hover:text-text transition-colors text-2xl"
              aria-label={link.label}
            >
              <i class={"fa-brands fa-" + link.icon} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
