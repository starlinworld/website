---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import { servers, landscapeItems, featureItems } from "../data";
---

<Layout title="Introduction | StarlinWorld">
  <main>
    {/* Hero Section */}
    <section
      id="hero"
      class="flex items-center justify-center px-6 pt-24 pb-12"
    >
      <div class="max-w-4xl mx-auto text-center">
        <div class="mb-8">
          <div class="w-32 h-32 md:w-40 md:h-40 mx-auto mb-8">
            <img
              src="/brand/mark_circle.svg"
              alt="StarlinWorld"
              class="w-full h-full"
            />
          </div>
          <h1 class="text-4xl md:text-5xl font-display font-bold mb-6">
            StarlinWorld
          </h1>
          <p class="text-base md:text-lg text-text/90 leading-relaxed">
            A cozy, stable, smooth, long-running virtual world with no world
            resets.
            <br />
            Here, every traveler in this virtual world shines like a brilliant star,
            standing among the radiant cosmos.
          </p>
        </div>
      </div>
    </section>

    {/* Servers Section */}
    <section id="servers" class="px-6 py-12 bg-background">
      <div class="max-w-6xl mx-auto">
        <div class="mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
            Servers
          </h2>
          <p class="text-lg text-text/80">
            We have multiple subservers running currently.
          </p>
        </div>
        <div class="grid md:grid-cols-2 gap-8 mb-12">
          {
            servers.map((server) => (
              <a
                href={server.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative overflow-hidden rounded-xl md:rounded-2xl block"
              >
                <div class="aspect-video overflow-hidden">
                  <img
                    src={server.image}
                    alt={server.name}
                    class="w-full h-full object-cover brightness-50 group-hover:brightness-80 transition-discrete duration-200"
                  />
                </div>

                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <div class="w-16 h-16 mb-4 rounded-full bg-primary/20 flex items-center justify-center">
                    <i class={`${server.icon} text-primary text-2xl`} />
                  </div>
                  <div class="flex items-center gap-2">
                    <h3 class={`text-xl md:text-2xl font-bold ${server.color}`}>
                      {server.name}
                    </h3>
                    <span class="relative inline-flex items-center justify-center w-5 h-5">
                      <i
                        class={`fa-solid fa-angle-right ${server.color} absolute transition-all duration-200 group-hover:translate-x-1`}
                      />
                      <i
                        class={`fa-solid fa-arrow-right ${server.color} absolute rotate-0 opacity-0 transition-all duration-200 group-hover:opacity-100`}
                      />
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
        <div class="flex justify-center">
          <Button href="/join" variant="primary">
            Join the server today
          </Button>
        </div>
      </div>
    </section>

    {/* Features Section */}
    <section id="features" class="px-6 py-12">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-display font-bold mb-12">
          Features
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            featureItems.slice(0, 3).map((feature) => (
              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary/20 flex items-center justify-center">
                  <i class={`${feature.icon} text-primary text-2xl`} />
                </div>
                <h3 class="text-xl font-bold mb-2">{feature.title}</h3>
                <p class="text-text/70 text-sm leading-relaxed">
                  {feature.description}
                </p>
              </div>
            ))
          }
        </div>
        <div class="grid md:grid-cols-2 gap-8 mt-8 max-w-4xl mx-auto">
          {
            featureItems.slice(3).map((feature) => (
              <div class="text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary/20 flex items-center justify-center">
                  <i class={`${feature.icon} text-primary text-2xl`} />
                </div>
                <h3 class="text-xl font-bold mb-2">{feature.title}</h3>
                <p class="text-text/70 text-sm leading-relaxed">
                  {feature.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* Landscape Section */}
    <section class="px-6 py-12 bg-background">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-display font-bold mb-12">
          Landscape
        </h2>
        <div class="space-y-12">
          {
            landscapeItems.map((landscape, index) => (
              <div
                class={`flex ${
                  index % 2 === 1 ? "justify-end" : "justify-start"
                }`}
              >
                <div class="w-full md:w-3/5">
                  <Card
                    image={landscape.src}
                    title={landscape.title}
                    alt={landscape.title}
                    width={landscape.width}
                    height={landscape.height}
                  />
                </div>
              </div>
            ))
          }
        </div>
        <div class="flex justify-center mt-16">
          <Button href="/gallery" variant="secondary">
            More in our Gallery
          </Button>
        </div>
      </div>
    </section>
  </main>
</Layout>
